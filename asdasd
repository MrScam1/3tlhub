local CONFIG = {
    Speed = 500,
    PROMPT_OFFSET = Vector3.new(0, 4, 0),
}
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
Busy = false
local lastWallTP = 0
local WALL_TP_COOLDOWN = 0.2
local function GetChar()
    local Char = LocalPlayer.Character
    if Char then
        return Char, Char:FindFirstChild("HumanoidRootPart"), Char:FindFirstChild("Humanoid")
    end
    return nil, nil, nil
end

local function GetRoot()
    local _, root, _ = GetChar()
    return root
end
local function AllToVector(Val) -- GetDistance Sub Function
    local Returner
    if Val then
        if typeof(Val) == "CFrame" then
            Returner = Val.Position
        elseif type(Val) == "vector" then
            Returner = Val
        elseif typeof(Val) == "Instance" and Val:IsA("BasePart") then
            Returner = Val.Position
        elseif Val:FindFirstChild("HumanoidRootPart") then
            Returner = Val:FindFirstChild("HumanoidRootPart").Position
        end
    end
    return Returner
end
local function IsFishMan(pos)
    return pos.Y < -2000
end
local function GetDistance(Object1, Object2)
    Object2 = Object2 or LocalPlayer.Character
    local Pos1, Pos2 = AllToVector(Object1), AllToVector(Object2)
    if Pos1 and Pos2 then
        return (Pos1 - Pos2).magnitude
    end
    return print("Invalid Type", debug.traceback())
end
local function TweenMove(Pos, Condition, ForceYPos, Farming)
    local character, rootPart, humanoid = GetChar()
    if not rootPart or not humanoid then return end
    
    local Speed = CONFIG.Speed

    local targetPosition = AllToVector(Pos)
    local Condition = Condition or function() return true end
    local HighY = ForceYPos and rootPart.Position.Y + ForceYPos or rootPart.Position.Y
    local dt = task.wait() 
    if ForceYPos then
        rootPart.CFrame = CFrame.new(rootPart.Position.X, rootPart.Position.Y + ForceYPos, rootPart.Position.Z)
    end
    while GetDistance(targetPosition) > 1 and Condition() do

        if not rootPart.Parent then break end
        local currentPos = rootPart.Position
        local delta = targetPosition - currentPos
        local distXZ = Vector3.new(delta.X, 0, delta.Z).Magnitude
        local dirXZ = distXZ > 0 and Vector3.new(delta.X, 0, delta.Z).Unit or Vector3.zero

        local moveDistance = Speed * dt 
        
        if moveDistance > distXZ then moveDistance = distXZ end

        local nextXZ = currentPos + dirXZ * moveDistance
        local finalPos = Vector3.zero
        if distXZ <= 1 then
            rootPart.CFrame = CFrame.new(targetPosition)
            break
        end
        finalPos = Vector3.new(nextXZ.X, ForceYPos and HighY or rootPart.Position.Y, nextXZ.Z)
        if finalPos.Y < 0 and currentPos.Y > - 500 then
            finalPos = Vector3.new(finalPos.X, CONFIG.ForceWaterHeight, finalPos.Z)
        end
        
        rootPart.CFrame = CFrame.new(finalPos)
        dt = task.wait() 
    end
end
TweenMove(workspace.Island1.Beach.Position, nil, 100)
