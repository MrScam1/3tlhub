local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local Window = Fluent:CreateWindow({
    Title = "God Hub",
    SubTitle = "Mr.Scam",
    TabWidth = 120,
    Size = UDim2.fromOffset(400, 320),
    Acrylic = true,                        -- The blur may be detectable, setting this to false disables blur entirely
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.RightControl -- Used when theres no MinimizeKeybind
})

getgenv().LoadTab = getgenv().LoadTab or {
    ["Farming"] = true,
    ["Misc"] = true,
}
local UiOrders = {
    { Title = "Farming", Icon = "" },
    --{ Title = "Misc", Icon = "" }
}
local UiIntilize = {
    Farming = {
        ['Auto Farm Stats'] = {
            Mode = "Toggle",
            Children = {
                Default = Config.Farming['Auto Mixer'] or false,
                Callback = function(Value)
                    print(123)
                    Config.Farming['Auto Mixer'] = Value
                end
            }
        }
    }
}

local function BuildUi(Tab, Children)
    for Name, args in Children do
        if args.Mode == "Toggle" then
            Tab:AddToggle("Toggle",{
                Title = Name,
                Default = args.Children.Default,
                Callback = args.Children.Callback
            })
        end
    end
end
for _, Children in UiOrders do
    local Tab = Window:AddTab({ Title = Children.Title, Icon = Children.Icon })
    BuildUi(Tab, UiIntilize[Children.Title])
end
