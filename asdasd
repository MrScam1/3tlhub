-- 1. Hook __newindex để khóa Text luôn là "10/10"
local oldNewIndex
oldNewIndex = hookmetamethod(game, "__newindex", function(self, key, value)
    -- Kiểm tra nếu script game đang cố thay đổi thuộc tính Text của Object tên là "Count"
    if not checkcaller() and self.Name == "Count" and key == "Text" then
        -- Ép nó luôn hiển thị 10/10 bất kể game muốn set là bao nhiêu
        return oldNewIndex(self, key, "10/10")
    end
    return oldNewIndex(self, key, value)
end)
