local PriorityQueue = {}
function PriorityQueue:new()
    local obj = { queue = {}, indexMap = {} }
    setmetatable(obj, self)
    self.__index = self
    return obj
end

function PriorityQueue:push(element, priority)
    if self.indexMap[element] then return end -- Prevent duplicates
    local task = { element = element, priority = priority }
    table.insert(self.queue, task)
    self.indexMap[element] = #self.queue -- Store the index
    self:sortQueue()
end

function PriorityQueue:pop(element)
    local index = self.indexMap[element]
    if index then
        local removedTask = table.remove(self.queue, index)
        self.indexMap[element] = nil -- Remove from index map
        self:updateIndices(index)
        return removedTask
    end
end

function PriorityQueue:top()
    return self.queue[1] and self.queue[1].element
end

function PriorityQueue:empty()
    return #self.queue == 0
end

function PriorityQueue:sortQueue()
    table.sort(self.queue, function(a, b)
        return a.priority > b.priority
    end)
    for i, task in ipairs(self.queue) do
        self.indexMap[task.element] = i -- Update indices
    end
end

function PriorityQueue:updateIndices(startIndex)
    for i = startIndex, #self.queue do
        local task = self.queue[i]
        if task then
            self.indexMap[task.element] = i
        end
    end
end

