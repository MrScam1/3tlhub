function SaveSettings(m, n)
    if m ~= nil then
        getgenv().Setting[m] = n
    end
    if not isfolder(i) then
        makefolder(i)
    end
    writefile(i .. "/" .. l, game:GetService("HttpService"):JSONEncode(getgenv().Setting))
end

function ReadSetting()
    local s, o =
        pcall(
            function()
                HttpService = game:GetService("HttpService")
                if not isfolder(i) then
                    makefolder(i)
                end
                return isfile(i .. "/" .. l) and HttpService:JSONDecode(readfile(i .. "/" .. l))
            end
        )
    if s and o then
        return o
    else
        SaveSettings()
        return ReadSetting()
    end
end

